%%{init: {'theme': 'base', 'flowchart': {'useMaxWidth': false, 'markdownAutoWrap': false, 'nodeSpacing': 30, 'rankSpacing': 35}, 'themeVariables': { 'primaryColor': '#e0e0e0', 'primaryTextColor': '#1a1a1a', 'primaryBorderColor': '#666', 'lineColor': '#4a4a4a', 'secondaryColor': '#f0f0f0', 'tertiaryColor': '#fafafa', 'fontFamily': 'Arial, sans-serif', 'fontSize': '13pt'}}}%%
flowchart TB
    %% Validated Query Cycle - Compact version

    subgraph CYCLE["<b>Validated Query Cycle</b>"]
        Q["<b>1. QUERY</b><br/>Expert asks question"]
        G["<b>2. GENERATION</b><br/>System generates SQL"]
        V{"<b>3. VALIDATION</b><br/>AI explains logic;<br/>Expert confirms"}
        S["<b>4. STORAGE</b><br/>Triple stored"]
        R["<b>5. RETRIEVAL</b><br/>Future queries match"]
        P["<b>6. PERSISTENCE</b><br/>Knowledge survives turnover"]
    end

    subgraph PILLARS["<b>Three Pillars</b>"]
        direction LR
        M["<b>Analytics<br/>Maturity</b>"]
        T["<b>Workforce<br/>Agility</b>"]
        B["<b>Technical<br/>Enablement</b>"]
    end

    %% Main cycle flow
    Q --> G --> V
    V -->|"Correct"| S --> R --> P
    V -->|"Incorrect"| G
    P -->|"New expert uses validated queries"| Q

    %% How cycle advances each pillar
    S -.->|"Advances"| M
    P -.->|"Stabilizes"| T
    R -.->|"Increases"| B

    %% Styling
    classDef group fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef dashedGroup fill:#e8e8e8,stroke:#666,stroke-width:2px,stroke-dasharray:5 5
    classDef decision fill:#f5f5f5,stroke:#444,stroke-width:2px
    class CYCLE group
    class PILLARS dashedGroup
    class V decision
